{
  "mcpServers": {
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp"
    },
    "sonarqube": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run", "-i", "--rm", "--init", "--pull=always",
        "--network", "sonar-net",
        "-e", "SONARQUBE_TOKEN",
        "-e", "SONARQUBE_URL",
        "mcp/sonarqube"
      ],
      "env": {
        "SONARQUBE_TOKEN": "${SONAR_TOKEN}",
        "SONARQUBE_URL": "http://sonarqube:9000"
      }
    }
  }
}
